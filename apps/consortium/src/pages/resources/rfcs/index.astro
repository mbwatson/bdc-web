---
import { getCollection } from 'astro:content';
import Base from '@layouts/Base.astro';

const rfcs = (await getCollection('rfcs')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Base title="RFCs & Memos">
  <h1>RFCs & Memos</h1>

  <table class="usa-table usa-table--borderless width-full">
    <thead>
      <tr>
        <th scope="col">Title</th>
        <th scope="col">Date</th>
        <th scope="col">Status</th>
      </tr>
    </thead>
    <tbody>
      {rfcs.map((rfc) => (
        <tr>
          <td>
            <a href={rfc.data.url} class="usa-link" target="_blank" rel="noopener noreferrer">
              {rfc.data.title}
            </a>
          </td>
          <td>
            {rfc.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </td>
          <td>
            <span class="usa-tag">{rfc.data.status}</span>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>Templates</h2>

  <div class="usa-alert usa-alert--info">
    <div class="usa-alert__body">
      <p class="usa-alert__text">RFC and memo templates coming soon.</p>
    </div>
  </div>
</Base>
