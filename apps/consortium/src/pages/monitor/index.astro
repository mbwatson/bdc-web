---
import Base from '@layouts/Base.astro';
---

<Base title="Monitor Dashboard">
  <section class="usa-section">
    <div class="grid-container">
      <h1>Monitor Dashboard</h1>

      <p>
        View the consortium monitoring dashboard for real-time status updates on platform services and infrastructure.
      </p>

      <a
        href="https://monitor.biodatacatalyst.nhlbi.nih.gov"
        class="usa-button"
        target="_blank"
        rel="noopener noreferrer"
      >
        Open Monitor Dashboard
      </a>
    </div>
  </section>
</Base>
